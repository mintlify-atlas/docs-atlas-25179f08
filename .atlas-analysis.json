  "keyFeatures": [
    "Gestión de mesas con estados (Disponible, Ocupada, Reservada, Limpieza, Mantenimiento)",
    "Flujo de pedidos de extremo a extremo: creación, preparación, entrega y cierre",
    "Facturación electrónica con soporte para Consumidor Final y Crédito Fiscal",
    "Sistema de roles y permisos granular (Administrador, Mesero, Cajero, Cocina)",
    "Gestión de empleados con autenticación segura mediante bcrypt",
    "Auditoría completa de acciones con registro de datos anteriores y nuevos (JSON)",
    "Menú con categorías, imágenes y disponibilidad por platillo",
    "Sistema de rangos de cliente (Bronce, Plata, Oro) con descuentos automáticos"
  ],
  "publicApiSurface": [
    "POST /api/login",
    "GET /api/usuario",
    "POST /api/mesas",
    "POST /api/mesas/bulk",
    "GET /api/mesas",
    "DELETE /api/mesas/:id",
    "PATCH /api/mesas/:id/estado",
    "POST /api/pedidos/iniciar",
    "POST /api/pedidos/crear",
    "POST /api/platillos",
    "GET /api/platillos",
    "GET /api/platillos/:id",
    "PUT /api/platillos/:id",
    "PATCH /api/platillos/:id/estado",
    "POST /api/empleados",
    "GET /api/empleados",
    "DELETE /api/empleados/:id",
    "PUT /api/empleados/:id"
  ]
